# Spot order-book engine configuration (env-driven).
# Copy to .env and adjust. All values shown are defaults.

# Comma-separated market symbols (base/quote).
OB_MARKETS=BTC/USDT,ETH/USDT,SOL/USDT

# SPSC ring capacity per link. Must be a power of two.
OB_RING_SIZE=65536

# Write-ahead log directory.
OB_WAL_PATH=./data/wal

# Journaling mode: "async" (a dedicated journaller goroutine fsyncs off the
# matcher — higher durable throughput, clears 1M TPS; the recommended default) or
# "sync" (inline fsync on the sequencer goroutine — simpler, fewer cores, fine at
# modest load). OB_JOURNAL_RING sizes the async hand-off ring (power of two, or 0
# for the engine default); ignored in sync mode.
OB_JOURNAL_MODE=async
OB_JOURNAL_RING=0

# Fixed-point scale for prices and quantities (1e8 = 8 decimals).
OB_PRICE_SCALE=100000000
OB_QTY_SCALE=100000000

# Fee rates as fixed-point fractions at OB_FEE_SCALE (1e8).
# Example: 0.001 (10 bps) = 100000. Both must be >= 0.
OB_FEE_SCALE=100000000
OB_MAKER_FEE=0
OB_TAKER_FEE=0

# Snapshot durability (restart-speed optimization over the full WAL).
# Snapshot directory; must differ from OB_WAL_PATH.
OB_SNAPSHOT_PATH=./data/snapshots
# Snapshot every N applied commands (0 disables count-based).
OB_SNAPSHOT_EVERY=0
# Snapshot every N seconds (0 disables time-based). Default: hourly.
OB_SNAPSHOT_INTERVAL=3600
# Keep the last K snapshot files (must be >= 1).
OB_SNAPSHOT_RETAIN=3

# Per-market order filters (CEX-style). MANDATORY for every market in OB_MARKETS;
# the default markets ship with built-in defaults, but a market added via
# OB_MARKETS must supply its own values or the engine refuses to start.
# Keys: OB_FILTER_<SYMBOL>_<FIELD>, where <SYMBOL> is the market uppercased with
# "/" and "-" replaced by "_" (e.g. BTC/USDT -> BTC_USDT). All values are integer
# fixed-point at OB_PRICE_SCALE / OB_QTY_SCALE (notional at OB_PRICE_SCALE).
# Fields: TICK_SIZE, MIN_PRICE, MAX_PRICE (price filter);
#         STEP_SIZE, MIN_QTY, MAX_QTY (lot filter, limit/stop-limit);
#         MKT_STEP_SIZE, MKT_MIN_QTY, MKT_MAX_QTY (market/stop-market lot filter);
#         MIN_NOTIONAL, MAX_NOTIONAL (notional filter).
# MIN_PRICE must be a multiple of TICK_SIZE; MIN_QTY of STEP_SIZE; MKT_MIN_QTY of
# MKT_STEP_SIZE. Example overrides for BTC/USDT (defaults shown):
# OB_FILTER_BTC_USDT_TICK_SIZE=1000000
# OB_FILTER_BTC_USDT_MIN_PRICE=1000000
# OB_FILTER_BTC_USDT_MAX_PRICE=100000000000000
# OB_FILTER_BTC_USDT_STEP_SIZE=10000
# OB_FILTER_BTC_USDT_MIN_QTY=10000
# OB_FILTER_BTC_USDT_MAX_QTY=1000000000000
# OB_FILTER_BTC_USDT_MKT_STEP_SIZE=10000
# OB_FILTER_BTC_USDT_MKT_MIN_QTY=10000
# OB_FILTER_BTC_USDT_MKT_MAX_QTY=1000000000000
# OB_FILTER_BTC_USDT_MIN_NOTIONAL=1000000000
# OB_FILTER_BTC_USDT_MAX_NOTIONAL=1000000000000000
